# Database connection (set one of them)
COOLIFY_DATABASE_URL=postgresql://user:password@host:5432/database
# DATABASE_URL=postgresql://user:password@host:5432/database

# Security hardening for first owner bootstrap (recommended in production)
OWNER_SETUP_KEY=replace-with-a-long-random-string

# DB SSL settings for production
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=true
